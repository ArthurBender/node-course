<div class="form-control">
  <label for="name">Name:</label>
  <input type="text" name="name" placeholder="John Doe" value="{{user.name}}" />
</div>

<div class="form-control">
  <label for="occupation">Occupation:</label>
  <input type="text" name="occupation" placeholder="Programmer" value="{{user.occupation}}" />
</div>

<div class="form-control checkbox">
  <label for="enabledNewsletter">Enable Newsletter:</label>
  <input type="checkbox" name="enabledNewsletter" id="enabledNewsletter" {{#if user.enabledNewsletter}}checked{{/if}} />
</div>

<button type="submit">Save</button>